# Copier vers .env : cp .env.example .env && nano .env

# n8n (interface)
N8N_BASIC_AUTH_USER=
N8N_BASIC_AUTH_PASSWORD=

# PostgreSQL interne n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change_me_strong_n8n_db_password
POSTGRES_DB=n8n

# Base métier FogLifter (matching, logs)
FOGLIFTER_DB_USER=foglifter
FOGLIFTER_DB_PASSWORD=change_me_strong_foglifter_db_password
FOGLIFTER_DB_NAME=foglifter

# Domaine public (HTTPS derrière Caddy / Traefik / NPM)
N8N_HOST=n8n.example.com
N8N_PROTOCOL=https

# Clés API (références — les workflows n8n utilisent les Credentials UI)
# Si renseignée ici, n8n reçoit OPENAI_API_KEY (voir docker-compose) pour le node HTTP OpenAI.
OPENAI_API_KEY=

# Telegram (node « Telegram alerte » — chat_id numérique ou @canal)
TELEGRAM_CHAT_ID=

# Recommandé en production : clé de chiffrement des credentials n8n (32+ caractères aléatoires)
N8N_ENCRYPTION_KEY=

# Si tu termines derrière un reverse-proxy HTTPS
WEBHOOK_URL=

# Composer 2 — optionnel : webhook broker / exécution (à consommer dans n8n si tu branches un node HTTP)
BROKER_WEBHOOK_URL=

# --- PostgreSQL (tuning ; valeurs par défaut adaptées petit VPS) ---
POSTGRES_N8N_SHARED_BUFFERS=128MB
POSTGRES_N8N_EFFECTIVE_CACHE=512MB
POSTGRES_N8N_WORK_MEM=8MB
POSTGRES_N8N_MAINTENANCE_WORK_MEM=64MB
POSTGRES_N8N_MAX_CONNECTIONS=100

POSTGRES_FL_SHARED_BUFFERS=256MB
POSTGRES_FL_EFFECTIVE_CACHE=1536MB
POSTGRES_FL_WORK_MEM=12MB
POSTGRES_FL_MAINTENANCE_WORK_MEM=128MB
POSTGRES_FL_MAX_CONNECTIONS=150

# --- n8n — exécutions (secondes pour les timeouts ; heures pour la rétention) ---
EXECUTIONS_DATA_PRUNE=true
EXECUTIONS_DATA_MAX_AGE=336
EXECUTIONS_TIMEOUT=300
EXECUTIONS_TIMEOUT_MAX=900
N8N_PAYLOAD_SIZE_MAX=32
N8N_DEFAULT_BINARY_DATA_MODE=filesystem

# --- Sauvegardes (scripts/backup-foglifter.sh) ---
BACKUP_ROOT=./backups
RETENTION_DAYS=14

# --- Brique « données managées » (optionnel — remplace / complète Postgres self-host) ---
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=

# --- Redis managé (optionnel — cache / queue hors n8n intégré) ---
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# --- LLM alternatif (ex. Groq pour MVP rapide) ---
# GROQ_API_KEY=

# FIRECRAWL_API_KEY=
# RESEND_API_KEY=
# TELEGRAM_BOT_TOKEN=
# AIRTABLE_API_KEY=
# INSEE_SIRENE_TOKEN=
