# =============================================================================
# FogLifter — variables d'environnement
# Copier :  cp .env.example .env
# Puis éditer .env (ne jamais le committer — déjà dans .gitignore)
# =============================================================================

# -----------------------------------------------------------------------------
# OBLIGATOIRE pour un premier déploiement fonctionnel
# -----------------------------------------------------------------------------
# Mots de passe forts (génère-les au hasard, 24+ caractères).
POSTGRES_PASSWORD=
FOGLIFTER_DB_PASSWORD=

# Clé OpenAI pour les nœuds HTTP des workflows exportés (Bearer).
OPENAI_API_KEY=

# Chat Telegram où envoyer les alertes (nombre ou @canal).
TELEGRAM_CHAT_ID=

# Production n8n : obligatoire pour chiffrer les credentials stockés dans n8n.
# Génère par ex. :  openssl rand -hex 32
N8N_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Très fortement recommandé (sécurité interface n8n)
# -----------------------------------------------------------------------------
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=
N8N_BASIC_AUTH_PASSWORD=

# -----------------------------------------------------------------------------
# Identifiants Postgres (valeurs par défaut = celles attendues par docker-compose)
# -----------------------------------------------------------------------------
POSTGRES_USER=n8n
POSTGRES_DB=n8n
FOGLIFTER_DB_USER=foglifter
FOGLIFTER_DB_NAME=foglifter

# -----------------------------------------------------------------------------
# URLs n8n (HTTPS une fois le reverse-proxy en place)
# -----------------------------------------------------------------------------
N8N_HOST=n8n.example.com
N8N_PROTOCOL=https
WEBHOOK_URL=

# -----------------------------------------------------------------------------
# Optionnel — Composer 2 / intégrations
# -----------------------------------------------------------------------------
BROKER_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# Optionnel — tuning PostgreSQL (voir docker-compose.yml)
# -----------------------------------------------------------------------------
POSTGRES_N8N_SHARED_BUFFERS=128MB
POSTGRES_N8N_EFFECTIVE_CACHE=512MB
POSTGRES_N8N_WORK_MEM=8MB
POSTGRES_N8N_MAINTENANCE_WORK_MEM=64MB
POSTGRES_N8N_MAX_CONNECTIONS=100

POSTGRES_FL_SHARED_BUFFERS=256MB
POSTGRES_FL_EFFECTIVE_CACHE=1536MB
POSTGRES_FL_WORK_MEM=12MB
POSTGRES_FL_MAINTENANCE_WORK_MEM=128MB
POSTGRES_FL_MAX_CONNECTIONS=150

# -----------------------------------------------------------------------------
# Optionnel — n8n exécutions (secondes = timeouts ; heures = rétention prune)
# -----------------------------------------------------------------------------
EXECUTIONS_DATA_PRUNE=true
EXECUTIONS_DATA_MAX_AGE=336
EXECUTIONS_TIMEOUT=300
EXECUTIONS_TIMEOUT_MAX=900
N8N_PAYLOAD_SIZE_MAX=32
N8N_DEFAULT_BINARY_DATA_MODE=filesystem

# -----------------------------------------------------------------------------
# Optionnel — sauvegardes (scripts/backup-foglifter.sh)
# -----------------------------------------------------------------------------
BACKUP_ROOT=./backups
RETENTION_DAYS=14

# -----------------------------------------------------------------------------
# Optionnel — briques managées (migration progressive)
# -----------------------------------------------------------------------------
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# GROQ_API_KEY=

# -----------------------------------------------------------------------------
# Autres intégrations (références — souvent via Credentials n8n plutôt qu'ici)
# -----------------------------------------------------------------------------
# FIRECRAWL_API_KEY=
# RESEND_API_KEY=
# TELEGRAM_BOT_TOKEN=
# AIRTABLE_API_KEY=
# INSEE_SIRENE_TOKEN=
